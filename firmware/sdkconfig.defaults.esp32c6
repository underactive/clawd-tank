# firmware/sdkconfig.defaults.esp32c6
#
# Waveshare ESP32-C6-LCD-1.47 (ESP32-C6FH8, 8 MB embedded flash, no PSRAM).

# Flash (ESP32-C6FH8 has 8 MB embedded flash)
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="8MB"

# Board selector
CONFIG_BOARD_WAVESHARE_C6_LCD147=y
CONFIG_BOARD_FREENOVE_S3_28=n
